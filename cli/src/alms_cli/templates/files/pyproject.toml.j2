[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "ALMS AI-first backend starter"
readme = "README.md"
requires-python = ">=3.13"
dependencies = [
{% for dep in all_deps %}    "{{ dep }}",
{% endfor %}]

[project.optional-dependencies]
dev = [
    "httpx>=0.28.1",
    "pytest>=9.0.2",
    "pytest-asyncio>=1.3.0",
    "ruff>=0.14.11",
]

[dependency-groups]
dev = [
    "httpx>=0.28.1",
    "pytest>=9.0.2",
    "pytest-asyncio>=1.3.0",
    "ruff>=0.14.11",
]

[tool.pytest.ini_options]
asyncio_mode = "auto"

[tool.alms]
profile = "{{ profile }}"
capabilities = {{ capabilities_repr }}
