# Application identity
APP_NAME={{ project_name }}
APP_DESCRIPTION=Backend API for {{ project_name }}
APP_VERSION=0.1.0
SERVICE_NAME={{ project_name | lower | replace(' ', '-') }}

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
# WARNING: ALLOWED_HOSTS=["*"] is for development only.
# Production must use explicit origins, e.g. ALLOWED_HOSTS=["https://example.com"]
ALLOWED_HOSTS=["*"]

# Environment Configuration
DEBUG=True
SECRET_KEY=generate-a-secure-key-here

# Security Configuration
X_API_KEY=

# API Configuration
API_PREFIX=/api

# Logging Configuration
LOG_LEVEL=info
LOG_SAVE_TO_FILE=false
LOG_FILE=src/logs/app.log
LOG_AUTO_SETUP=true
{% if has_ai %}
# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL_BASIC=gpt-4o-mini
OPENAI_MODEL_REASONING=gpt-4o
{% endif %}{% if has_db %}
# Database Configuration (PostgreSQL)
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
{% endif %}{% if has_redis %}
# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
{% endif %}{% if has_obs %}
# Observability
METRICS_ENABLED=true
TRACING_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
{% endif %}