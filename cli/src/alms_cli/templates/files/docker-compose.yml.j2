version: '3.8'

services:{% if has_db %}
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: mydb
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: secret
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
{% endif %}{% if has_redis %}
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
{% endif %}
volumes:{% if has_db %}
  postgres_data:{% endif %}{% if has_redis %}
  redis_data:{% endif %}
